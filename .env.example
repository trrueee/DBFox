# =============================================================================
# DBFox 环境变量模板
# 此文件不是密钥模板。不要把真实凭据、数据库 URL、运行时路径或安全开关写入 .env。
# DBFox 对 .env 只读取明确白名单中的非敏感性能/端口参数；其余配置必须由父进程
# 注入环境变量，LLM/LangSmith/数据源凭据必须写入 OS Credential Vault。
# =============================================================================

# ---- 凭据与 Provider 配置 ----
# LLM、LangSmith 和数据源凭据均不支持 dotenv。请通过应用界面登记，系统只保存
# opaque credential ID；Provider endpoint 也应通过应用配置和 URL policy 校验。

# ---- 引擎运行时 ----
# 后端端口（默认 18625，一般无需修改）
# DBFOX_ENGINE_PORT=18625

# 可选的、允许从 .env 读取的资源上限（均为非敏感调优参数）
# DBFOX_DB_POOL_SIZE=20
# DBFOX_DB_MAX_OVERFLOW=20
# DBFOX_DB_POOL_RECYCLE_SECONDS=1800
# DBFOX_DB_POOL_TIMEOUT_SECONDS=30
# DBFOX_SQLITE_TIMEOUT_SECONDS=30
# DBFOX_SQL_MAX_POOLS=16
# DBFOX_SQL_MAX_CONNECTIONS=64
# DBFOX_EXPORT_MAX_ROWS=100000
# DBFOX_EXPORT_TIMEOUT_MS=30000
# DBFOX_AGENT_CHECKPOINT_RETENTION_DAYS=30
# DBFOX_AGENT_CHECKPOINT_MAX_TERMINAL_RUNS=500
# DBFOX_AGENT_CHECKPOINT_MAX_BYTES=536870912

# DBFOX_DATABASE_URL、DBFOX_RUNTIME_DIR、DBFOX_ENGINE_TOKEN、DBFOX_TESTING、
# DBFOX_ALLOW_GUARDRAIL_BYPASS 等安全相关变量不会从 .env 加载。如确有部署需要，
# 仅由受控的服务管理器/CI 注入进程环境。
